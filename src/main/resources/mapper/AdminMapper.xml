      <select id="getUserPrivilege" parameterType="string" resultMap="UserPrivilege">
            SELECT  FRPRIVGRP_PRIV.PRIV_ID
            FROM FRUSER, FRUSER_PRIVGRP, FRPRIVGRP, FRPRIVGRP_PRIV
            WHERE FRUSER.D_THESYSTEMKEY = FRUSER_PRIVGRP.D_THESYSTEMKEY
            AND FRUSER_PRIVGRP.PRIVGRP_KEY = FRPRIVGRP.PRIVGRP_KEY
            AND FRPRIVGRP.D_THESYSTEMKEY = FRPRIVGRP_PRIV.D_THESYSTEMKEY
            AND FRPRIVGRP.SUBSYSTEM_ID = 'WFM'
            AND FRUSER.USER_ID = #{USERID}
            AND FRPRIVGRP_PRIV.PERMISSION ='Y'
            order by FRUSER.USER_ID
      </select>
      -->
        <select id="getUserPrivilege" parameterType="string" resultMap="UserPrivilege">
            SELECT DISTINCT  A.PRIV_ID,A.PERMISSION
            FROM V_MESDUSERG_FUNC A
            WHERE 1 = 1
            AND A.USERG_ID IN (SELECT USERG_ID
            FROM V_MESDUSER_GROUP
            WHERE USER_ID = #{USERID} )
            ORDER BY PRIV_ID
        </select>




    </mapper>